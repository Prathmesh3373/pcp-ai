{
  "name": "pcp-ai",
  "version": "0.1.0",
  "description": "A local Personal Context Protocol server for AI applications.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pcp": "dist/index.js",
    "pcp-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "serve": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "mcp:dev": "tsx src/mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js",
    "test:search": "tsx src/test-search.ts",
    "prepack": "npm run typecheck && npm run build"
  },
  "keywords": [
    "pcp",
    "personal-context",
    "mcp",
    "ai",
    "local-first",
    "memory",
    "ollama",
    "codex"
  ],
  "author": "Prathmesh Kagalkar",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "pcp-ai": "^0.1.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.61.1",
    "supermemory": "^4.24.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
